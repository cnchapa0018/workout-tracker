# Caddy config for the WorkIn.ai SPA (served on Railway via nixpacks).
# Paths are relative to the start CWD (the app dir), so this is portable
# regardless of the absolute build path.
{
	admin off
	persist_config off
	auto_https off
}

:{$PORT:80} {
	root * dist
	encode zstd gzip

	# Content-hashed build assets are immutable — safe to cache for a year.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Everything else — the index.html shell, all SPA routes, sw.js, manifest,
	# icons — must revalidate on every load so a fresh deploy reaches users
	# immediately (etag makes the revalidation a cheap 304). This is the fix for
	# stale shells that previously required a hard refresh.
	@dynamic {
		not path /assets/*
	}
	header @dynamic Cache-Control "no-cache"

	# SPA fallback: unknown routes serve the app shell.
	try_files {path} /index.html
	file_server
}
